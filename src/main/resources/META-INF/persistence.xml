<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">


    <persistence-unit name="watches" transaction-type="RESOURCE_LOCAL">
        <properties>

            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/watches"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="root"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- HikariCP Connection Pool Configuration -->
            <property name="hibernate.connection.provider_class" value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>

            <!-- Maximum number of connections in the pool (default: 10) -->
            <property name="hibernate.hikari.maximumPoolSize" value="30"/>

            <!-- Minimum number of idle connections maintained (default: same as maximumPoolSize)
                 Set to lower value to save resources during low traffic -->
            <property name="hibernate.hikari.minimumIdle" value="10"/>

            <!-- Maximum time (ms) a connection can sit idle before being removed -->
            <property name="hibernate.hikari.idleTimeout" value="600000"/>

            <!-- Maximum time (ms) to wait for a connection from pool  -->
            <property name="hibernate.hikari.connectionTimeout" value="5000"/>

            <!-- Maximum lifetime (ms) of a connection in pool -->
            <property name="hibernate.hikari.maxLifetime" value="1800000"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

        </properties>
    </persistence-unit>
</persistence>